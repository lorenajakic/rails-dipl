<!DOCTYPE html>
<html class="h-full bg-gray-50">
  <head>
    <title><%= content_for(:title) || t('app_name') %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <% if user_signed_in? && current_user.avatar.attached? %>
      <link rel="preload" as="image" href="<%= url_for(current_user.avatar) %>">
    <% end %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full"<% if user_signed_in? %> data-current-user-id="<%= current_user.id %>"<% end %>>
    <% if user_signed_in? %>
      <nav class="bg-white shadow-sm border-b border-gray-200">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
          <div class="flex h-16 justify-between">
            <div class="flex items-center">
              <%= link_to root_path, class: "flex items-center gap-2 text-indigo-600 font-bold text-xl" do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <%= t('app_name') %>
              <% end %>
            </div>

            <div class="flex items-center gap-4">
              <div class="flex items-center gap-1 text-xs">
                <% I18n.available_locales.each do |loc| %>
                  <% if loc == I18n.locale %>
                    <span class="px-1.5 py-0.5 rounded bg-indigo-100 text-indigo-700 font-semibold uppercase"><%= loc %></span>
                  <% else %>
                    <%= link_to loc.to_s.upcase, locale_switch_path(loc), class: "px-1.5 py-0.5 rounded text-gray-400 hover:text-gray-600 uppercase" %>
                  <% end %>
                <% end %>
              </div>

              <%= link_to invitations_path, class: "relative p-2 rounded-full text-gray-500 hover:text-gray-700 hover:bg-gray-100 transition" do %>
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0" /></svg>
                <% if pending_invitations_count > 0 %>
                  <span class="absolute top-0.5 right-0.5 flex h-4 min-w-[1rem] items-center justify-center rounded-full bg-red-500 px-1 text-[10px] font-bold text-white ring-2 ring-white"><%= pending_invitations_count %></span>
                <% end %>
              <% end %>

              <div class="relative" data-controller="dropdown">
                <button type="button" data-action="click->dropdown#toggle" class="flex items-center gap-2 rounded-full bg-gray-100 px-3 py-1.5 text-sm font-medium text-gray-700 hover:bg-gray-200 transition">
                  <% if current_user.avatar.attached? %>
                    <%= image_tag current_user.avatar, class: "h-7 w-7 rounded-full object-cover" %>
                  <% else %>
                    <span class="flex h-7 w-7 items-center justify-center rounded-full bg-indigo-600 text-xs font-semibold text-white">
                      <%= current_user.name.first.upcase %>
                    </span>
                  <% end %>
                  <span class="hidden sm:inline"><%= current_user.name %></span>
                  <svg class="h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                </button>

                <div data-dropdown-target="menu" class="hidden absolute right-0 z-10 mt-2 w-48 origin-top-right rounded-md bg-white py-1 shadow-lg ring-1 ring-black/5">
                  <%= link_to t('nav.profile'), profile_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" %>
                  <%= button_to t('nav.sign_out'), destroy_user_session_path, method: :delete, class: "block w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" %>
                </div>
              </div>
            </div>
          </div>
        </div>
      </nav>
    <% end %>

    <div class="fixed bottom-6 right-6 z-50 flex flex-col gap-3 pointer-events-none">
      <% if notice.present? %>
        <div data-controller="toast" data-toast-delay-value="4000"
             class="pointer-events-auto translate-y-4 opacity-0 transition-all duration-300 ease-out rounded-lg bg-white shadow-lg ring-1 ring-gray-200 p-4 max-w-sm">
          <div class="flex items-start gap-3">
            <svg class="h-5 w-5 text-green-500 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
            <p class="text-sm font-medium text-gray-800"><%= notice %></p>
            <button type="button" data-action="toast#dismiss" class="ml-auto -mr-1 shrink-0 text-gray-400 hover:text-gray-600">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
            </button>
          </div>
        </div>
      <% end %>

      <% if alert.present? %>
        <div data-controller="toast" data-toast-delay-value="5000"
             class="pointer-events-auto translate-y-4 opacity-0 transition-all duration-300 ease-out rounded-lg bg-white shadow-lg ring-1 ring-red-200 p-4 max-w-sm">
          <div class="flex items-start gap-3">
            <svg class="h-5 w-5 text-red-500 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd" /></svg>
            <p class="text-sm font-medium text-gray-800"><%= alert %></p>
            <button type="button" data-action="toast#dismiss" class="ml-auto -mr-1 shrink-0 text-gray-400 hover:text-gray-600">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
            </button>
          </div>
        </div>
      <% end %>
    </div>

    <main class="<%= user_signed_in? ? 'mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8' : 'h-full' %>">
      <%= yield %>
    </main>

    <%# Custom confirm modal — very high z-index (above Leaflet panes/popups); scroll lock in confirm_controller %>
    <div data-controller="confirm" data-action="keydown@document->confirm#keydown" class="relative z-[99999]">
      <div id="turbo-confirm-dialog"
           data-confirm-target="dialog"
           data-action="click->confirm#backdropClick"
           class="hidden fixed inset-0 z-[99999] flex items-center justify-center bg-black/40 p-4 backdrop-blur-sm">
        <div class="relative z-[100000] mx-auto w-full max-w-sm rounded-2xl bg-white p-6 shadow-xl ring-1 ring-gray-900/5">
          <div class="flex items-start gap-3">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-indigo-50">
              <svg class="h-5 w-5 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z" /></svg>
            </div>
            <div class="min-w-0 flex-1">
              <h3 class="text-sm font-semibold text-gray-900"><%= t('confirm_dialog.title') %></h3>
              <p data-confirm-target="message" class="mt-1 text-sm text-gray-600"></p>
            </div>
          </div>
          <div class="mt-5 flex flex-wrap justify-end gap-2">
            <button type="button" data-action="click->confirm#cancel"
                    class="rounded-lg border border-gray-200 bg-white px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50 transition cursor-pointer">
              <%= t('confirm_dialog.cancel') %>
            </button>
            <button type="button" data-action="click->confirm#accept" data-confirm-target="confirmBtn"
                    class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-700 transition cursor-pointer">
              <%= t('confirm_dialog.confirm') %>
            </button>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
