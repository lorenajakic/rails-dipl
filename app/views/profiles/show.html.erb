<div class="mx-auto max-w-2xl">
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-2xl font-bold text-gray-900"><%= t('profiles.title') %></h1>
    <div class="flex items-center gap-3">
      <%= link_to t('profiles.change_password'), edit_user_registration_path, class: "rounded-md bg-white px-4 py-2 text-sm font-semibold text-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50" %>
      <%= link_to t('profiles.edit_profile'), edit_profile_path, class: "rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500" %>
    </div>
  </div>

  <div class="overflow-hidden rounded-lg bg-white shadow">
    <div class="p-8">
      <div class="flex items-center gap-6">
        <% if current_user.avatar.attached? %>
          <%= image_tag current_user.avatar, class: "h-20 w-20 rounded-full object-cover ring-2 ring-indigo-100", width: 80, height: 80 %>
        <% else %>
          <span class="flex h-20 w-20 items-center justify-center rounded-full bg-indigo-600 text-2xl font-bold text-white ring-2 ring-indigo-100">
            <%= current_user.name.first.upcase %>
          </span>
        <% end %>

        <div>
          <h2 class="text-xl font-semibold text-gray-900"><%= current_user.name %></h2>
          <p class="text-sm text-gray-500"><%= current_user.email %></p>
        </div>
      </div>
    </div>
  </div>
</div>
