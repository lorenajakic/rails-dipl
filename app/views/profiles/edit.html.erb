<div class="mx-auto max-w-2xl">
  <h1 class="text-2xl font-bold text-gray-900 mb-8"><%= t('profiles.edit_title') %></h1>

  <div class="overflow-hidden rounded-lg bg-white shadow">
    <div class="p-8">
      <%= form_with model: current_user, url: profile_path, method: :patch, class: "space-y-6" do |f| %>
        <% if current_user.errors.any? %>
          <div class="rounded-md bg-red-50 p-4">
            <ul class="list-disc pl-5 text-sm text-red-800">
              <% current_user.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div>
          <%= f.label :name, t('profiles.name'), class: "block text-sm font-medium text-gray-700" %>
          <%= f.text_field :name, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm px-3 py-2 border" %>
        </div>

        <div>
          <%= f.label :avatar, t('profiles.avatar'), class: "block text-sm font-medium text-gray-700 mb-2" %>
          <div class="flex items-center gap-4">
            <% if current_user.avatar.attached? %>
              <%= image_tag current_user.avatar, class: "h-16 w-16 rounded-full object-cover", width: 64, height: 64 %>
            <% else %>
              <span class="flex h-16 w-16 items-center justify-center rounded-full bg-indigo-600 text-xl font-bold text-white">
                <%= current_user.name.first.upcase %>
              </span>
            <% end %>
            <%= f.file_field :avatar, accept: "image/*", class: "block text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100" %>
          </div>
        </div>

        <div class="flex items-center gap-4 pt-4">
          <%= f.submit t('profiles.save'), class: "rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 cursor-pointer" %>
          <%= link_to t('common.cancel'), profile_path, class: "text-sm font-semibold text-gray-700 hover:text-gray-900" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
