<%
  badge_classes = case status
                  when 'draft'
                    'bg-gray-100 text-gray-600'
                  when 'planning'
                    'bg-blue-100 text-blue-700'
                  when 'finalized'
                    'bg-green-100 text-green-700'
                  when 'completed'
                    'bg-purple-100 text-purple-700'
                  else
                    'bg-gray-100 text-gray-600'
                  end
%>
<span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold <%= badge_classes %>">
  <%= t("trips.statuses.#{status}") %>
</span>
