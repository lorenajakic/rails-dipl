<%= turbo_stream_from trip, :places %>

<div data-controller="map"
     data-map-places-value="<%= places.map { |p| { id: p.id, name: p.name, address: p.address, latitude: p.latitude.to_f, longitude: p.longitude.to_f, category: p.category } }.to_json %>"
     data-map-interactive-value="true"
     data-map-reverse-loading-value="<%= t('places.reverse_loading') %>"
     data-map-reverse-not-found-value="<%= t('places.reverse_not_found') %>"
     data-map-name-placeholder-value="<%= t('places.form.name_placeholder') %>">

  <div class="flex flex-col lg:flex-row gap-6">
    <%# LEFT — Search + Place list %>
    <div class="lg:w-[400px] shrink-0 space-y-4">
      <%# Autocomplete search %>
      <div data-controller="autocomplete" class="relative">
        <%= form_with url: trip_places_path(trip), method: :post, data: { autocomplete_target: "form", action: "turbo:submit-end->autocomplete#clearAfterSubmit" }, class: "space-y-3" do |f| %>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1"><%= t('places.form.category') %></label>
            <select name="place[category]" class="block w-full rounded-xl border border-gray-200 bg-white px-3 py-2 text-sm focus:border-indigo-300 focus:ring focus:ring-indigo-200 focus:ring-opacity-50">
              <% Place.categories.keys.each do |cat| %>
                <option value="<%= cat %>"><%= t("places.categories.#{cat}") %></option>
              <% end %>
            </select>
          </div>
          <div class="relative z-20">
            <div class="flex w-full items-center gap-2.5 rounded-xl border border-gray-200 bg-white px-3 py-2.5 shadow-sm focus-within:border-indigo-300 focus-within:ring focus-within:ring-indigo-200 focus-within:ring-opacity-50">
              <span class="flex shrink-0 items-center text-gray-400" aria-hidden="true">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
              </span>
              <input type="text"
                     data-autocomplete-target="input"
                     data-action="input->autocomplete#search keydown->autocomplete#onKeydown"
                     placeholder="<%= t('places.search_placeholder') %>"
                     autocomplete="off"
                     class="min-w-0 flex-1 border-0 bg-transparent p-0 text-sm text-gray-900 placeholder-gray-400 shadow-none outline-none ring-0 focus:ring-0" />
            </div>
            <div data-autocomplete-target="results" class="hidden absolute left-0 right-0 top-full z-30 mt-1 rounded-xl border border-gray-200 bg-white shadow-lg max-h-64 overflow-y-auto"></div>
          </div>

          <input type="hidden" name="place[name]" data-autocomplete-target="name" />
          <input type="hidden" name="place[address]" data-autocomplete-target="address" />
          <input type="hidden" name="place[latitude]" data-autocomplete-target="latitude" />
          <input type="hidden" name="place[longitude]" data-autocomplete-target="longitude" />
        <% end %>
      </div>

      <div id="place_form_errors"></div>

      <%# Map click: reverse-geocode (Photon) to read place name from coordinates %>
      <div data-map-target="clickForm" class="hidden">
        <%= form_with url: trip_places_path(trip), method: :post, data: { map_target: "clickSubmitForm", action: "turbo:submit-end->map#afterPlaceSubmit" }, class: "rounded-xl border border-indigo-200 bg-indigo-50/50 p-4 space-y-3" do |f| %>
          <div class="flex items-start gap-2 text-sm font-medium text-indigo-700">
            <svg class="h-4 w-4 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            <span><%= t('places.map_pick_title') %><span class="block text-xs font-normal text-indigo-600/90 mt-0.5"><%= t('places.map_pick_subtitle') %></span></span>
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1"><%= t('places.form.name') %></label>
            <input type="text" name="place[name]" data-map-target="clickName" required
                   placeholder="<%= t('places.form.name_placeholder') %>"
                   class="block w-full rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm focus:border-indigo-300 focus:ring focus:ring-indigo-200 focus:ring-opacity-50" />
          </div>
          <input type="hidden" name="place[address]" value="" data-map-target="clickAddress" />
          <div>
            <select name="place[category]" data-map-target="clickCategory"
                    class="block w-full rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm focus:border-indigo-300 focus:ring focus:ring-indigo-200 focus:ring-opacity-50">
              <% Place.categories.keys.each do |cat| %>
                <option value="<%= cat %>"><%= t("places.categories.#{cat}") %></option>
              <% end %>
            </select>
          </div>
          <input type="hidden" name="place[latitude]" data-map-target="clickLatitude" />
          <input type="hidden" name="place[longitude]" data-map-target="clickLongitude" />
          <div class="flex items-center gap-2">
            <button type="submit" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-500 transition cursor-pointer">
              <%= t('places.form.submit') %>
            </button>
            <button type="button" data-action="click->map#cancelPin" class="rounded-lg border border-gray-200 bg-white px-4 py-2 text-sm font-medium text-gray-600 hover:bg-gray-50 transition cursor-pointer">
              <%= t('common.cancel') %>
            </button>
          </div>
        <% end %>
      </div>

      <%# Place list %>
      <div>
        <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wide">
          <%= t('places.added_places', count: places.size) %>
        </h3>

        <div id="places_list" class="space-y-3 mt-3">
          <% places.each_with_index do |place, index| %>
            <%= render partial: 'trips/places/place_card', locals: { place: place, trip: trip, index: index } %>
          <% end %>
        </div>

        <% if places.empty? %>
          <div id="places_empty" class="py-10 text-center">
            <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-indigo-50 text-indigo-400 mb-3">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            </div>
            <p class="text-sm font-medium text-gray-600"><%= t('places.empty_title') %></p>
            <p class="mt-1 text-xs text-gray-400"><%= t('places.empty_hint') %></p>
          </div>
        <% end %>
      </div>
    </div>

    <%# RIGHT — Map %>
    <div class="flex-1 min-w-0">
      <div data-map-target="container" class="h-[400px] lg:h-[calc(100vh-16rem)] rounded-2xl border border-gray-200 overflow-hidden bg-gray-100"></div>
      <p class="mt-2 text-xs text-gray-400 text-center"><%= t('places.map_hint') %></p>
    </div>
  </div>
</div>
