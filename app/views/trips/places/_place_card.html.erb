<%= tag.div id: dom_id(place), class: "bg-white rounded-xl border border-gray-200 p-4 transition hover:shadow-sm", data: { place_json: { id: place.id, name: place.name, address: place.address, latitude: place.latitude.to_f, longitude: place.longitude.to_f, category: place.category }.to_json } do %>
  <div class="flex items-start justify-between gap-3">
    <div class="flex items-start gap-3 min-w-0">
      <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-xs font-bold text-white" style="background-color: <%= Place::CATEGORY_COLORS[place.category] || '#6b7280' %>">
        <%= index.present? ? index + 1 : '·' %>
      </span>
      <div class="min-w-0">
        <h4 class="text-sm font-semibold text-gray-900 truncate">
          <button type="button" data-action="click->map#highlightPlace" data-map-id-param="<%= place.id %>" class="hover:text-indigo-600 transition cursor-pointer">
            <%= place.name %>
          </button>
        </h4>
        <% if place.address.present? %>
          <p class="text-xs text-gray-500 truncate mt-0.5"><%= place.address %></p>
        <% end %>
        <div class="flex items-center gap-2 mt-1.5 flex-wrap">
          <span class="inline-flex items-center rounded-full px-2 py-0.5 text-[10px] font-medium" style="background-color: <%= Place::CATEGORY_COLORS[place.category] || '#6b7280' %>20; color: <%= Place::CATEGORY_COLORS[place.category] || '#6b7280' %>">
            <%= t("places.categories.#{place.category}") %>
          </span>
          <% if place.estimated_duration_minutes.present? %>
            <span class="inline-flex items-center gap-1 text-[10px] text-gray-400">
              <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              <%= place.estimated_duration_minutes %> min
            </span>
          <% end %>
        </div>
      </div>
    </div>

    <span data-controller="show-for-user" data-show-for-user-user-id-value="<%= place.added_by_id %>">
      <%= button_to trip_place_path(trip, place), method: :delete, class: "shrink-0 p-1 rounded-md text-gray-400 hover:text-red-500 hover:bg-red-50 transition cursor-pointer", data: { turbo_confirm: t('places.confirm_delete') } do %>
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
      <% end %>
    </span>
  </div>

  <div class="mt-2 text-[11px] text-gray-400">
    <%= t('places.added_by') %> <%= place.added_by.name %>
  </div>

  <%# Comments %>
  <div id="<%= dom_id(place, :comments) %>" class="mt-3 space-y-2">
    <% place.place_comments.includes(:user).order(created_at: :asc).each do |comment| %>
      <%= render partial: 'trips/places/comments/comment', locals: { comment: comment, trip: trip, place: place } %>
    <% end %>
  </div>

  <%= render partial: 'trips/places/comments/form', locals: { trip: trip, place: place } %>
<% end %>
