<%= tag.div id: dom_id(comment), class: "flex items-start gap-2 group" do %>
  <div class="flex-1 bg-gray-50 rounded-lg px-3 py-2">
    <div class="flex items-center gap-1.5">
      <span class="text-xs font-medium text-gray-700"><%= comment.user.name %></span>
      <span class="text-[10px] text-gray-400"><%= time_ago_in_words(comment.created_at) %></span>
    </div>
    <p class="text-xs text-gray-600 mt-0.5"><%= comment.body %></p>
  </div>
  <span data-controller="show-for-user" data-show-for-user-user-id-value="<%= comment.user_id %>" class="opacity-0 group-hover:opacity-100">
    <%= button_to trip_place_comment_path(trip, place, comment), method: :delete, class: "shrink-0 p-1 rounded text-gray-400 hover:text-red-500 transition cursor-pointer" do %>
      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
    <% end %>
  </span>
<% end %>
