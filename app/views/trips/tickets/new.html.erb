<turbo-frame id="tickets_panel">
  <%
    category_icons = {
      "flight"        => %(<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" /></svg>),
      "accommodation" => %(<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12M3 9h12M3 15h12" /></svg>),
      "activity"      => %(<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 6v.75m0 3v.75m0 3v.75m0 3V18m-9-5.25h5.25M1.5 15h5.25m7-5.25h5.25M1.5 9h5.25m7-5.25h5.25" /></svg>),
      "transport"     => %(<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" /></svg>),
      "other"         => %(<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" /></svg>)
    }
    category_colors = {
      "flight"        => "peer-checked:border-sky-400 peer-checked:bg-sky-50 peer-checked:text-sky-700",
      "accommodation" => "peer-checked:border-violet-400 peer-checked:bg-violet-50 peer-checked:text-violet-700",
      "activity"      => "peer-checked:border-emerald-400 peer-checked:bg-emerald-50 peer-checked:text-emerald-700",
      "transport"     => "peer-checked:border-amber-400 peer-checked:bg-amber-50 peer-checked:text-amber-700",
      "other"         => "peer-checked:border-gray-400 peer-checked:bg-gray-50 peer-checked:text-gray-700"
    }
    field_class = "block w-full rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm text-gray-900 shadow-sm placeholder:text-gray-400 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 focus:outline-none"
  %>

  <div class="mb-3">
    <%= link_to trip_tickets_path(@trip), class: "inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700" do %>
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
      <%= t("tickets.back_to_tickets_tab") %>
    <% end %>
  </div>

  <h3 class="text-base font-bold text-gray-900"><%= t("tickets.new_title") %></h3>
  <p class="text-xs text-gray-500 mt-0.5 mb-4"><%= t("tickets.new_subtitle", title: @trip.title) %></p>

  <% if @ticket.errors.any? %>
    <div class="mb-4 rounded-md bg-red-50 p-3">
      <div class="flex">
        <svg class="h-4 w-4 text-red-400 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd" /></svg>
        <div class="ml-2">
          <ul class="list-disc list-inside text-xs text-red-700">
            <% @ticket.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <%= form_with model: [@trip, @ticket],
      html: {
        class: "space-y-4",
        data: {
          controller: "file-upload",
          file_upload_max_bytes_value: 20.megabytes,
          action: "submit->file-upload#validateSubmit"
        }
      } do |f| %>

    <div>
      <p class="block text-xs font-semibold text-gray-700 mb-2"><%= t("tickets.form.category") %></p>
      <div class="flex gap-1.5">
        <% Ticket.categories.each_key.with_index do |cat, idx| %>
          <label class="flex-1 relative cursor-pointer">
            <%= f.radio_button :category, cat, class: "peer hidden", checked: idx == 0 %>
            <span class="flex flex-col items-center gap-0.5 rounded-lg border-2 border-gray-200 bg-white px-1.5 py-2 text-gray-500 text-[11px] font-medium transition hover:border-gray-300 <%= category_colors[cat] %>">
              <%= category_icons[cat].html_safe %>
              <%= t("tickets.categories.#{cat}") %>
            </span>
          </label>
        <% end %>
      </div>
    </div>

    <div>
      <%= f.label :title, t("tickets.form.title"), class: "block text-xs font-semibold text-gray-700 mb-1" %>
      <%= f.text_field :title, required: true, placeholder: t("tickets.form.title_placeholder"), class: field_class %>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <%= f.label :date, t("tickets.form.date"), class: "block text-xs font-semibold text-gray-700 mb-1" %>
        <%= f.date_field :date, class: field_class %>
      </div>
      <div>
        <p class="block text-xs font-semibold text-gray-700 mb-1"><%= t("tickets.form.cost_label") %></p>
        <div class="flex gap-1.5">
          <%= f.number_field :cost, step: "0.01", min: 0, placeholder: "0.00",
              class: "flex-1 min-w-0 rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm text-gray-900 shadow-sm placeholder:text-gray-400 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 focus:outline-none" %>
          <%= f.select :cost_currency, %w[EUR USD GBP HRK],
              {},
              class: "w-20 rounded-lg border border-gray-300 bg-white px-2 py-2 text-xs text-gray-900 shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 focus:outline-none" %>
        </div>
      </div>
    </div>

    <div>
      <%= f.label :details, t("tickets.form.details"), class: "block text-xs font-semibold text-gray-700 mb-1" %>
      <%= f.text_area :details, rows: 2, placeholder: t("tickets.form.details_placeholder"), class: field_class %>
    </div>

    <div>
      <p class="block text-xs font-semibold text-gray-700 mb-1"><%= t("tickets.form.file") %></p>
      <label class="flex items-center gap-3 rounded-lg border-2 border-dashed border-gray-300 bg-gray-50 px-4 py-4 cursor-pointer hover:border-indigo-400 hover:bg-indigo-50/30 transition group">
        <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-white shadow-sm ring-1 ring-gray-200 text-gray-400 group-hover:text-indigo-500 transition">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" /></svg>
        </span>
        <div>
          <p class="text-sm font-medium text-gray-700 group-hover:text-indigo-700 transition">
            <span data-file-upload-target="filename"><%= t("tickets.form.file_cta") %></span>
          </p>
          <p class="text-[11px] text-gray-400"><%= t("tickets.form.file_hint") %></p>
        </div>
        <%= f.file_field :file,
            accept: "application/pdf,image/jpeg,image/png,image/webp",
            required: true,
            class: "hidden",
            data: {
              file_upload_target: "input",
              action: "change->file-upload#pick",
              invalid_type_message: t("tickets.file_invalid_type"),
              too_large_message: t("tickets.file_too_large")
            } %>
      </label>
      <p data-file-upload-target="error" class="mt-1 text-xs text-red-600 hidden" role="alert"></p>
    </div>

    <div class="flex items-center gap-3 pt-1">
      <%= f.submit t("tickets.form.submit"), class: "inline-flex items-center rounded-lg bg-indigo-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 transition cursor-pointer" %>
      <%= link_to t("common.cancel"), trip_tickets_path(@trip), class: "text-sm font-medium text-gray-600 hover:text-gray-900" %>
    </div>

  <% end %>
</turbo-frame>
