<turbo-frame id="tickets_panel">
  <div class="space-y-4">
    <div class="flex items-center justify-between gap-4">
      <div>
        <div class="flex flex-wrap items-center gap-2">
          <span class="inline-flex items-center rounded-full bg-gray-100 px-2.5 py-0.5 text-xs font-semibold uppercase tracking-wide text-gray-600">
            <%= t("tickets.categories.#{@ticket.category}") %>
          </span>
          <h3 class="text-base font-semibold text-gray-900"><%= @ticket.title %></h3>
        </div>
        <% if @ticket.date.present? %>
          <p class="text-xs text-gray-400 mt-0.5"><%= l(@ticket.date, format: :long) %></p>
        <% end %>
      </div>
      <%= link_to trip_tickets_path(@trip), class: "shrink-0 inline-flex items-center gap-1.5 rounded-lg border border-gray-200 bg-white px-3 py-1.5 text-xs font-medium text-gray-600 hover:border-indigo-200 hover:bg-indigo-50/40 hover:text-indigo-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-indigo-200 transition" do %>
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
        <%= t("tickets.back_to_tickets_tab") %>
      <% end %>
    </div>

    <div class="rounded-xl border border-gray-200 bg-gray-50/80 p-4 sm:p-5 space-y-3">
      <% if @ticket.details.present? %>
        <div class="text-sm text-gray-700 whitespace-pre-wrap"><%= @ticket.details %></div>
      <% end %>

      <% if @ticket.cost_cents.present? %>
        <div class="flex items-center gap-2">
          <span class="text-xs font-semibold uppercase tracking-wider text-gray-400"><%= t("tickets.form.cost_label") %>:</span>
          <span class="text-sm font-semibold text-gray-900">
            <%= number_to_currency(@ticket.cost_cents.to_f / 100, unit: @ticket.cost_currency, format: "%n %u") %>
          </span>
        </div>
      <% end %>

      <div class="flex items-center gap-2 pt-2 border-t border-gray-100">
        <span class="text-xs text-gray-400"><%= t("tickets.uploaded_by") %></span>
        <% u = @ticket.uploaded_by %>
        <% if u.avatar.attached? %>
          <%= image_tag u.avatar, class: "h-6 w-6 rounded-full object-cover", width: 24, height: 24, alt: "" %>
        <% else %>
          <span class="flex h-6 w-6 items-center justify-center rounded-full bg-indigo-100 text-[9px] font-semibold text-indigo-600"><%= u.name.first.upcase %></span>
        <% end %>
        <span class="text-sm font-medium text-gray-700"><%= u.name %></span>
      </div>

      <% if @ticket.file.attached? %>
        <div class="pt-3 border-t border-gray-100">
          <%= link_to url_for(@ticket.file),
              target: "_blank", rel: "noopener",
              class: "inline-flex items-center gap-2 rounded-lg border border-indigo-600 bg-indigo-600 px-3 py-2 text-sm font-medium text-white hover:bg-indigo-500 hover:border-indigo-500 focus:outline-none focus-visible:ring-2 focus-visible:ring-indigo-300 transition" do %>
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" /></svg>
            <%= @ticket.file.content_type.to_s.include?("pdf") ? t("tickets.download_pdf") : t("tickets.download_image") %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</turbo-frame>
