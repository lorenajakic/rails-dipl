<%= form_with(model: trip, class: "space-y-6") do |f| %>
  <% if trip.errors.any? %>
    <div class="rounded-md bg-red-50 p-4">
      <div class="flex">
        <svg class="h-5 w-5 text-red-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd" /></svg>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800"><%= t('trips.form.errors_title') %></h3>
          <ul class="mt-2 list-disc list-inside text-sm text-red-700">
            <% trip.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <div>
    <%= f.label :title, t('trips.form.title'), class: "block text-sm font-semibold text-gray-700 mb-2" %>
    <%= f.text_field :title, class: "block w-full rounded-lg border border-gray-300 bg-white px-4 py-3 text-gray-900 shadow-sm placeholder:text-gray-400 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 focus:outline-none", placeholder: t('trips.form.title_placeholder') %>
  </div>

  <div class="relative" data-controller="destination-autocomplete">
    <%= f.label :destination, t('trips.form.destination'), class: "block text-sm font-semibold text-gray-700 mb-2" %>
    <%= f.text_field :destination,
        class: "block w-full rounded-lg border border-gray-300 bg-white px-4 py-3 text-gray-900 shadow-sm placeholder:text-gray-400 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 focus:outline-none",
        placeholder: t('trips.form.destination_placeholder'),
        autocomplete: "off",
        data: { destination_autocomplete_target: "input", action: "input->destination-autocomplete#search keydown->destination-autocomplete#keydown" } %>
    <div data-destination-autocomplete-target="results" class="absolute z-10 mt-1 w-full rounded-lg bg-white shadow-lg ring-1 ring-gray-200 hidden overflow-hidden"></div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
    <div>
      <%= f.label :start_date, t('trips.form.start_date'), class: "block text-sm font-semibold text-gray-700 mb-2" %>
      <%= f.text_field :start_date, type: "date", value: trip.start_date&.iso8601, class: "block w-full rounded-lg border border-gray-300 bg-white px-4 py-3 text-gray-900 shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 focus:outline-none" %>
    </div>

    <div>
      <%= f.label :end_date, t('trips.form.end_date'), class: "block text-sm font-semibold text-gray-700 mb-2" %>
      <%= f.text_field :end_date, type: "date", value: trip.end_date&.iso8601, class: "block w-full rounded-lg border border-gray-300 bg-white px-4 py-3 text-gray-900 shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 focus:outline-none" %>
    </div>
  </div>

  <div>
    <%= f.label :cover_image, t('trips.form.cover_image'), class: "block text-sm font-semibold text-gray-700 mb-2" %>
    <% if trip.cover_image.attached? %>
      <div class="mb-3 relative inline-block">
        <%= image_tag trip.cover_image, class: "rounded-lg object-cover h-20 w-auto", alt: trip.title %>
      </div>
    <% end %>
    <%= f.file_field :cover_image, accept: "image/*", class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2.5 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100 file:cursor-pointer" %>
    <p class="mt-1 text-xs text-gray-400"><%= t('trips.form.cover_image_hint') %></p>
  </div>

  <div class="flex items-center gap-4 pt-2">
    <%= f.submit class: "inline-flex items-center rounded-lg bg-indigo-600 px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 transition cursor-pointer" %>
    <%= link_to t('common.cancel'), (trip.persisted? ? trip_path(trip) : root_path), class: "text-sm font-medium text-gray-600 hover:text-gray-900" %>
  </div>
<% end %>
