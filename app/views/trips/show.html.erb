<div class="mb-4">
  <%= link_to root_path, class: "inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700" do %>
    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
    <%= t('trips.back_to_trips') %>
  <% end %>
</div>

<div class="flex flex-col lg:flex-row gap-6" data-controller="tabs" data-tabs-active-tab-class="bg-indigo-50 text-indigo-700 border-indigo-200" data-tabs-inactive-tab-class="text-gray-600 hover:bg-gray-50 border-transparent">

  <%# LEFT SIDEBAR %>
  <div class="lg:w-80 shrink-0">
    <div class="bg-white border border-gray-200 rounded-2xl overflow-hidden">
      <div class="h-24 bg-gradient-to-br from-indigo-500 to-purple-600 relative">
        <% if @trip.cover_image.attached? %>
          <%= image_tag @trip.cover_image, class: "absolute inset-0 h-full w-full object-cover", alt: @trip.title %>
          <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
        <% end %>
        <div class="absolute bottom-3 left-5 right-5 flex items-end justify-between">
          <h1 class="text-xl font-bold text-white drop-shadow-sm"><%= @trip.title %></h1>
          <%= render partial: 'dashboard/status_badge', locals: { status: @trip.status } %>
        </div>
      </div>

      <div class="p-5 space-y-5">
        <div class="flex items-center gap-3 text-sm text-gray-600">
          <svg class="h-5 w-5 text-gray-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          <span class="font-medium"><%= @trip.destination %></span>
        </div>

        <div class="flex items-center gap-3 text-sm text-gray-600">
          <svg class="h-5 w-5 text-gray-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
          <div>
            <span class="font-medium"><%= l(@trip.start_date, format: :short) %> &ndash; <%= l(@trip.end_date, format: :long) %></span>
            <span class="text-gray-400 ml-1">(<%= t('dashboard.days_count', count: @trip.duration_days) %>)</span>
          </div>
        </div>

        <div>
          <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2"><%= t('trips.show.participants') %></p>
          <div class="space-y-2">
            <% @trip.participants.each do |participant| %>
              <div class="flex items-center gap-2.5">
                <% if participant.avatar.attached? %>
                  <%= image_tag participant.avatar, class: "h-7 w-7 rounded-full object-cover", width: 28, height: 28 %>
                <% else %>
                  <span class="flex h-7 w-7 items-center justify-center rounded-full bg-indigo-100 text-xs font-semibold text-indigo-600">
                    <%= participant.name.first.upcase %>
                  </span>
                <% end %>
                <span class="text-sm text-gray-700"><%= participant.name %></span>
                <% if participant == @trip.creator %>
                  <span class="text-[10px] font-medium text-gray-400 uppercase"><%= t('trips.show.creator') %></span>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>

        <div class="border-t border-gray-100 pt-4">
          <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-3"><%= t('invitations.invite_title') %></p>
          <%= form_with url: trip_invitations_path(@trip), method: :post, class: "flex gap-2" do |f| %>
            <%= f.email_field :email, placeholder: t('invitations.email_placeholder'), required: true,
                class: "flex-1 rounded-lg border border-gray-200 px-3 py-2 text-sm focus:border-indigo-300 focus:ring focus:ring-indigo-200 focus:ring-opacity-50" %>
            <%= f.submit t('invitations.invite_button'), class: "rounded-lg bg-indigo-600 px-3 py-2 text-sm font-medium text-white hover:bg-indigo-700 transition cursor-pointer" %>
          <% end %>

          <% pending = @trip.trip_invitations.pending %>
          <% if pending.any? %>
            <div class="mt-3 space-y-1.5">
              <% pending.each do |inv| %>
                <div class="flex items-center gap-2">
                  <span class="flex h-7 w-7 items-center justify-center rounded-full bg-gray-100 text-xs font-semibold text-gray-400">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                  </span>
                  <span class="text-sm text-gray-500 truncate"><%= inv.email %></span>
                  <span class="ml-auto inline-flex items-center rounded-full bg-amber-50 px-2 py-0.5 text-[10px] font-medium text-amber-700"><%= t('invitations.pending_badge') %></span>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>

        <% if @trip.creator == current_user %>
          <div class="border-t border-gray-100 pt-4 flex gap-2">
            <%= link_to edit_trip_path(@trip), class: "inline-flex items-center gap-1.5 rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50 transition" do %>
              <svg class="h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
              <%= t('trips.show.edit') %>
            <% end %>
            <%= button_to trip_path(@trip), method: :delete, class: "inline-flex items-center gap-1.5 rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm font-medium text-red-600 hover:bg-red-50 hover:border-red-200 transition", data: { turbo_confirm: t('trips.confirm_delete') } do %>
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
              <%= t('trips.show.delete') %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <%# RIGHT SIDE — Tabs + Content %>
  <div class="flex-1 min-w-0">
    <div class="flex gap-2 mb-6 overflow-x-auto">
      <% [:places, :itinerary, :chat, :tickets].each_with_index do |tab_name, i| %>
        <button data-tabs-target="tab" data-action="tabs#select" data-tabs-index-param="<%= i %>"
                class="inline-flex items-center gap-2 rounded-lg border px-4 py-2.5 text-sm font-medium transition whitespace-nowrap text-gray-600 hover:bg-gray-50 border-transparent">
          <%= t("trips.tabs.#{tab_name}") %>
        </button>
      <% end %>
    </div>

    <% [:places, :itinerary, :chat, :tickets].each_with_index do |tab_name, i| %>
      <div data-tabs-target="panel" class="hidden">
        <% if tab_name == :places %>
          <%= render 'trips/places/panel', trip: @trip, places: @places %>
        <% elsif tab_name == :tickets %>
          <div class="bg-white border border-gray-200 rounded-2xl p-6 sm:p-8">
            <turbo-frame id="tickets_panel">
              <%= render "trips/tickets/list", trip: @trip, tickets: @tickets, tickets_category_filter: @tickets_category_filter %>
            </turbo-frame>
          </div>
        <% else %>
          <div class="bg-white border border-gray-200 rounded-2xl p-10 text-center">
            <h3 class="text-sm font-semibold text-gray-900"><%= t("trips.tabs.#{tab_name}") %></h3>
            <p class="mt-1 text-sm text-gray-500"><%= t("trips.placeholders.#{tab_name}") %></p>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
